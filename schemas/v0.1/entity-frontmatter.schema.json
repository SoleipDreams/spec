{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everendforge.github.io/spec/schemas/v0.1/entity-frontmatter.schema.json",
  "title": "Everend Entity Frontmatter v0.1",
  "type": "object",
  "required": ["id", "type", "name", "status"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "parentId": {
      "type": "string",
      "minLength": 1
    },
    "childrenIds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": true
}
