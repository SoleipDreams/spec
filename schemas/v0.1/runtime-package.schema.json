{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everendforge.github.io/spec/schemas/v0.1/runtime-package.schema.json",
  "title": "Everend Runtime Package v0.1",
  "type": "object",
  "required": ["specVersion", "packageId", "entryNodeId", "nodes"],
  "properties": {
    "specVersion": {
      "const": "0.1"
    },
    "packageId": {
      "type": "string",
      "minLength": 1
    },
    "entryNodeId": {
      "type": "string",
      "minLength": 1
    },
    "canonRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      },
      "uniqueItems": true
    },
    "variables": {
      "type": "object",
      "additionalProperties": true
    },
    "localization": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "speakerRef": {
            "type": "string",
            "minLength": 1
          },
          "textKey": {
            "type": "string",
            "minLength": 1
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "textKey", "targetNodeId"],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "textKey": {
                  "type": "string",
                  "minLength": 1
                },
                "targetNodeId": {
                  "type": "string",
                  "minLength": 1
                },
                "conditions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                },
                "consequences": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  }
                }
              },
              "additionalProperties": true
            }
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "consequences": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
